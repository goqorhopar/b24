{
  "tools": {
    "meeting_join": {
      "name": "meeting_join",
      "description": "Join a meeting and start recording audio/video with real meeting access",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meeting_url": {
            "type": "string",
            "description": "Meeting URL to join (Zoom, Google Meet, Teams, etc.)"
          },
          "platform": {
            "type": "string",
            "enum": ["zoom", "meet", "teams", "telemost"],
            "description": "Meeting platform type"
          },
          "auto_join": {
            "type": "boolean",
            "description": "Automatically join without waiting for user confirmation",
            "default": true
          }
        },
        "required": ["meeting_url"]
      },
      "implementation": {
        "type": "meeting_automation",
        "browser": "chrome",
        "headless": true,
        "timeout": 120,
        "actions": [
          "navigate_to_url",
          "find_join_button",
          "click_join",
          "mute_audio",
          "start_recording"
        ],
        "logging": {
          "level": "info",
          "file": "logs/meeting_join.log"
        }
      }
    },
    "meeting_analyze": {
      "name": "meeting_analyze",
      "description": "Analyze meeting transcript using Gemini AI and generate actionable insights",
      "inputSchema": {
        "type": "object",
        "properties": {
          "transcript": {
            "type": "string",
            "description": "Meeting transcript text"
          },
          "meeting_url": {
            "type": "string",
            "description": "Original meeting URL"
          },
          "lead_id": {
            "type": "string",
            "description": "Lead ID for CRM integration"
          },
          "analysis_type": {
            "type": "string",
            "enum": ["full", "summary", "tasks_only"],
            "description": "Type of analysis to perform",
            "default": "full"
          }
        },
        "required": ["transcript", "meeting_url"]
      },
      "implementation": {
        "type": "gemini_ai",
        "model": "gemini-1.5-flash",
        "prompt_template": "meeting_analysis",
        "output_format": "json",
        "max_tokens": 4000,
        "api_key_env": "GEMINI_KEY",
        "logging": {
          "level": "info",
          "file": "logs/gemini_analysis.log"
        }
      }
    },
    "bitrix_update": {
      "name": "bitrix_update",
      "description": "Update Bitrix24 CRM with meeting results and create tasks",
      "inputSchema": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string",
            "description": "Lead ID to update"
          },
          "summary": {
            "type": "string",
            "description": "Meeting summary"
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "task": {"type": "string"},
                "deadline": {"type": "string"},
                "assignee": {"type": "string"},
                "priority": {"type": "string"}
              }
            },
            "description": "Generated tasks from meeting"
          },
          "status": {
            "type": "string",
            "enum": ["NEW", "IN_PROCESS", "MEETING_COMPLETED", "QUALIFIED", "UNQUALIFIED"],
            "description": "Lead status to set",
            "default": "MEETING_COMPLETED"
          },
          "comments": {
            "type": "string",
            "description": "Additional comments for lead"
          }
        },
        "required": ["lead_id", "summary"]
      },
      "implementation": {
        "type": "bitrix_api",
        "endpoints": {
          "update_lead": "crm.lead.update",
          "create_task": "tasks.task.add",
          "add_comment": "crm.lead.comment.add"
        },
        "timeout": 30,
        "api_key_env": "BITRIX_TOKEN",
        "logging": {
          "level": "info",
          "file": "logs/bitrix_update.log"
        }
      }
    },
    "transcript_processing": {
      "name": "transcript_processing",
      "description": "Process audio recording and convert to text transcript using Whisper",
      "inputSchema": {
        "type": "object",
        "properties": {
          "audio_file": {
            "type": "string",
            "description": "Path to audio file"
          },
          "language": {
            "type": "string",
            "description": "Audio language code",
            "default": "ru"
          },
          "format": {
            "type": "string",
            "enum": ["whisper", "google_stt", "azure_stt"],
            "description": "Speech-to-text service",
            "default": "whisper"
          }
        },
        "required": ["audio_file"]
      },
      "implementation": {
        "type": "speech_to_text",
        "service": "whisper",
        "model": "whisper-1",
        "language": "ru",
        "format": "json",
        "api_key_env": "OPENAI_API_KEY",
        "logging": {
          "level": "info",
          "file": "logs/transcript_processing.log"
        }
      }
    },
    "meeting_recording": {
      "name": "meeting_recording",
      "description": "Record meeting audio and video with real recording capabilities",
      "inputSchema": {
        "type": "object",
        "properties": {
          "duration": {
            "type": "integer",
            "description": "Recording duration in minutes",
            "default": 60
          },
          "audio_only": {
            "type": "boolean",
            "description": "Record only audio",
            "default": false
          },
          "quality": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Recording quality",
            "default": "medium"
          }
        }
      },
      "implementation": {
        "type": "audio_recording",
        "format": "wav",
        "sample_rate": 44100,
        "channels": 2,
        "logging": {
          "level": "info",
          "file": "logs/meeting_recording.log"
        }
      }
    },
    "checklist_generation": {
      "name": "checklist_generation",
      "description": "Generate comprehensive meeting checklist using Gemini AI with real business value",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meeting_type": {
            "type": "string",
            "enum": ["sales", "demo", "follow-up", "discovery", "negotiation", "presentation"],
            "description": "Type of meeting for checklist generation"
          },
          "lead_info": {
            "type": "string",
            "description": "Lead information including company, role, pain points"
          },
          "industry": {
            "type": "string",
            "description": "Industry sector for customized checklist"
          },
          "meeting_duration": {
            "type": "integer",
            "description": "Expected meeting duration in minutes",
            "default": 60
          }
        },
        "required": ["meeting_type"]
      },
      "implementation": {
        "type": "gemini_ai",
        "model": "gemini-1.5-flash",
        "prompt_template": "meeting_checklist",
        "output_format": "json",
        "max_tokens": 3000,
        "api_key_env": "GEMINI_KEY",
        "temperature": 0.7,
        "logging": {
          "level": "info",
          "file": "logs/checklist_generation.log"
        },
        "validation": {
          "required_fields": ["pre_meeting", "during_meeting", "post_meeting", "documentation", "next_steps"],
          "max_items_per_section": 10
        }
      }
    }
  }
}
