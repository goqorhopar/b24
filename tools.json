{
  "tools": [
    {
      "name": "meeting_join",
      "description": "Подключение к онлайн-встрече",
      "parameters": {
        "type": "object",
        "properties": {
          "meeting_url": {
            "type": "string",
            "description": "URL встречи для подключения"
          }
        },
        "required": ["meeting_url"]
      },
      "implementation": {
        "function": "meeting_join",
        "description": "Реально подключается к встрече, определяет платформу и логирует подключение"
      }
    },
    {
      "name": "meeting_analyze",
      "description": "Анализ транскрипта встречи через Gemini AI",
      "parameters": {
        "type": "object",
        "properties": {
          "transcript": {
            "type": "string",
            "description": "Транскрипт встречи для анализа"
          },
          "meeting_url": {
            "type": "string",
            "description": "URL встречи (опционально)"
          }
        },
        "required": ["transcript"]
      },
      "implementation": {
        "function": "meeting_analyze",
        "description": "Отправляет транскрипт в Gemini AI и возвращает структурированный анализ с задачами и оценкой лида"
      }
    },
    {
      "name": "checklist",
      "description": "Создание чеклиста задач через Gemini AI",
      "parameters": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Текст для создания чеклиста"
          }
        },
        "required": ["prompt"]
      },
      "implementation": {
        "function": "checklist",
        "description": "Анализирует текст через Gemini AI и создает структурированный чеклист задач"
      }
    },
    {
      "name": "bitrix_update",
      "description": "Обновление лида и создание задач в Bitrix24",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "integer",
            "description": "ID лида для обновления"
          },
          "summary": {
            "type": "string",
            "description": "Резюме встречи"
          },
          "tasks": {
            "type": "array",
            "description": "Список задач для создания",
            "items": {
              "type": "object",
              "properties": {
                "task": {"type": "string"},
                "assignee": {"type": "string"},
                "deadline": {"type": "string"},
                "priority": {"type": "string"}
              }
            }
          },
          "lead_score": {
            "type": "integer",
            "description": "Оценка лида (1-10)"
          }
        },
        "required": ["lead_id", "summary", "tasks", "lead_score"]
      },
      "implementation": {
        "function": "bitrix_update",
        "description": "Реально обновляет лид в Bitrix24 и создает задачи через API"
      }
    }
  ],
  "error_handling": {
    "gemini_api_error": {
      "description": "Ошибка API Gemini",
      "fallback": "Возвращает error с кодом и трассировкой"
    },
    "bitrix_api_error": {
      "description": "Ошибка API Bitrix24",
      "fallback": "Возвращает error с кодом HTTP и деталями"
    },
    "json_parse_error": {
      "description": "Ошибка парсинга JSON ответа",
      "fallback": "Возвращает error с исходным текстом ответа"
    }
  }
}